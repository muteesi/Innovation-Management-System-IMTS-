@page
@model IMTS.Pages.ItAdmin.ReportsModel
<div class="space-y-lg">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="bg-success/10 text-success px-lg py-md rounded-sm font-label-md text-label-md flex items-center gap-sm border border-success/20">
            <span class="material-symbols-outlined">check_circle</span>
            <span>@Model.SuccessMessage</span>
        </div>
    }

    <div class="bg-white rounded-sm shadow-soft border border-outline-variant/40 p-lg">
        <div class="flex items-center gap-sm mb-md">
            <span class="material-symbols-outlined text-brand-gold">description</span>
            <h2 class="font-label-lg text-label-lg font-bold text-on-surface">Generate Report</h2>
        </div>
        <form method="post" asp-page-handler="Generate" class="flex flex-wrap items-end gap-md">
            <div class="w-64">
                <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Report Type</label>
                <select asp-for="ReportType" class="w-full px-md py-2 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required>
                    <option value="">Select Report Type</option>
                    @foreach (var rt in Model.ReportTypes)
                    {
                        <option value="@rt">@rt</option>
                    }
                </select>
            </div>
            <div>
                <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">From Date</label>
                <input asp-for="DateFrom" type="date" class="px-md py-2 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" />
            </div>
            <div>
                <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">To Date</label>
                <input asp-for="DateTo" type="date" class="px-md py-2 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" />
            </div>
            <div class="w-32">
                <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Format</label>
                <select asp-for="ReportFormat" class="w-full px-md py-2 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md">
                    <option value="PDF">PDF</option>
                    <option value="Excel">Excel</option>
                    <option value="CSV">CSV</option>
                </select>
            </div>
            <button type="submit" class="px-lg py-2 bg-brand-gold hover:bg-[#c47e1d] text-white font-label-md text-label-md rounded-sm transition-colors flex items-center gap-xs">
                <span class="material-symbols-outlined text-sm">play_arrow</span>
                <span>Generate Report</span>
            </button>
        </form>
    </div>

    <div class="bg-white rounded-sm shadow-soft border border-outline-variant/40 overflow-hidden">
        <div class="px-lg py-md border-b border-outline-variant/30 flex items-center gap-sm">
            <span class="material-symbols-outlined text-brand-gold">folder</span>
            <h2 class="font-label-lg text-label-lg font-bold text-on-surface">Generated Reports</h2>
            <span class="px-sm py-0.5 bg-surface-container-low text-on-surface-variant rounded-sm font-label-sm text-label-sm">@Model.Reports.Count reports</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-surface-container-low text-left font-label-sm text-label-sm text-on-surface-variant">
                        <th class="px-lg py-sm font-medium">Report Name</th>
                        <th class="px-lg py-sm font-medium">Format</th>
                        <th class="px-lg py-sm font-medium">Generated</th>
                        <th class="px-lg py-sm font-medium">Generated By</th>
                        <th class="px-lg py-sm font-medium">Status</th>
                        <th class="px-lg py-sm font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model.Reports)
                    {
                        <tr class="border-t border-outline-variant/20 hover:bg-surface-container-low transition-colors">
                            <td class="px-lg py-sm">
                                <div class="flex items-center gap-sm">
                                    <span class="material-symbols-outlined text-brand-gold">@(report.Format == "PDF" ? "picture_as_pdf" : report.Format == "Excel" ? "table_chart" : "text_snippet")</span>
                                    <span class="font-label-md text-label-md font-medium text-on-surface">@report.Name</span>
                                </div>
                            </td>
                            <td class="px-lg py-sm">
                                <span class="px-sm py-0.5 rounded-sm font-label-sm text-label-sm bg-surface-container-low text-on-surface-variant font-semibold uppercase">@report.Format</span>
                            </td>
                            <td class="px-lg py-sm font-body-md text-body-md text-on-surface-variant">@report.GeneratedAt.ToString("MMM dd, yyyy HH:mm")</td>
                            <td class="px-lg py-sm font-body-md text-body-md text-on-surface-variant">@report.GeneratedBy</td>
                            <td class="px-lg py-sm">
                                <span class="inline-flex items-center gap-xs px-sm py-0.5 rounded-sm font-label-sm text-label-sm bg-success/10 text-success">
                                    <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
                                    @report.Status
                                </span>
                            </td>
                            <td class="px-lg py-sm">
                                <div class="flex items-center gap-xs">
                                    <button class="p-xs hover:bg-surface-container-high rounded-sm transition-colors" title="Download">
                                        <span class="material-symbols-outlined text-sm text-on-surface-variant">download</span>
                                    </button>
                                    <button class="p-xs hover:bg-surface-container-high rounded-sm transition-colors" title="View">
                                        <span class="material-symbols-outlined text-sm text-on-surface-variant">visibility</span>
                                    </button>
                                    <button class="p-xs hover:bg-surface-container-high rounded-sm transition-colors" title="Delete">
                                        <span class="material-symbols-outlined text-sm text-on-surface-variant">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
