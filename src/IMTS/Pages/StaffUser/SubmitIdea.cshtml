@page
@model IMTS.Pages.StaffUser.SubmitIdeaModel
@{
    var steps = new[] { "Innovator Details", "Idea Details", "Benefits & Alignment", "Review & Submit" };
}

<div class="max-w-4xl mx-auto space-y-lg">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="bg-green-100 text-green-800 p-md rounded-sm font-label-md text-label-md">@Model.SuccessMessage</div>
    }

    <div class="bg-white rounded-sm shadow-soft p-lg">
        <div class="flex items-center justify-between mb-lg">
            @for (int i = 0; i < steps.Length; i++)
            {
                var stepNum = i + 1;
                var isActive = stepNum == Model.CurrentStep;
                var isCompleted = stepNum < Model.CurrentStep;
                <div class="flex items-center flex-1 @(i < steps.Length - 1 ? "after:content-[''] after:flex-1 after:h-0.5 after:mx-sm after:rounded-full " + (isCompleted || (isActive && i > 0) ? "after:bg-brand-gold" : "after:bg-outline-variant") : "")">
                    <div class="flex items-center gap-sm @(isActive ? "text-brand-gold" : isCompleted ? "text-green-600" : "text-outline")">
                        <div class="w-9 h-9 rounded-full flex items-center justify-center font-label-md text-label-md font-bold @(isActive ? "bg-brand-gold text-white" : isCompleted ? "bg-green-100 text-green-600" : "bg-outline-variant/30 text-outline")">
                            @if (isCompleted)
                            {
                                <span class="material-symbols-outlined text-[18px]">check</span>
                            }
                            else
                            {
                                @stepNum
                            }
                        </div>
                        <span class="font-label-sm text-label-sm hidden sm:inline @(isActive ? "font-bold" : "")">@steps[i]</span>
                    </div>
                </div>
            }
        </div>

        <form method="post" class="space-y-lg">
            <input type="hidden" asp-for="CurrentStep" />

            @if (Model.CurrentStep == 1)
            {
                <div class="space-y-md">
                    <h3 class="font-title-md text-title-md font-bold text-brand-maroon">Innovator Details</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="FullName">Full Name <span class="text-red-500">*</span></label>
                            <input asp-for="FullName" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required />
                            <span asp-validation-for="FullName" class="text-red-500 font-label-sm text-label-sm"></span>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="Email">Email <span class="text-red-500">*</span></label>
                            <input asp-for="Email" type="email" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required />
                            <span asp-validation-for="Email" class="text-red-500 font-label-sm text-label-sm"></span>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="Department">Department <span class="text-red-500">*</span></label>
                            <input asp-for="Department" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required />
                            <span asp-validation-for="Department" class="text-red-500 font-label-sm text-label-sm"></span>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="JobTitle">Job Title <span class="text-red-500">*</span></label>
                            <input asp-for="JobTitle" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required />
                            <span asp-validation-for="JobTitle" class="text-red-500 font-label-sm text-label-sm"></span>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="Location">Location</label>
                            <input asp-for="Location" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" />
                        </div>
                    </div>
                </div>
            }
            else if (Model.CurrentStep == 2)
            {
                <div class="space-y-md">
                    <h3 class="font-title-md text-title-md font-bold text-brand-maroon">Idea Details</h3>
                    <div class="grid grid-cols-1 gap-md">
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="IdeaTitle">Idea Title <span class="text-red-500">*</span></label>
                            <input asp-for="IdeaTitle" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required />
                            <span asp-validation-for="IdeaTitle" class="text-red-500 font-label-sm text-label-sm"></span>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="Summary">Summary <span class="text-red-500">*</span></label>
                            <textarea asp-for="Summary" rows="3" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required></textarea>
                            <span asp-validation-for="Summary" class="text-red-500 font-label-sm text-label-sm"></span>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="ProblemStatement">Problem Statement <span class="text-red-500">*</span></label>
                            <textarea asp-for="ProblemStatement" rows="3" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required></textarea>
                            <span asp-validation-for="ProblemStatement" class="text-red-500 font-label-sm text-label-sm"></span>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="ProposedSolution">Proposed Solution <span class="text-red-500">*</span></label>
                            <textarea asp-for="ProposedSolution" rows="3" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required></textarea>
                            <span asp-validation-for="ProposedSolution" class="text-red-500 font-label-sm text-label-sm"></span>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface">Innovation Type</label>
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-sm">
                                @foreach (var type in new[] { "Process", "Product", "Service", "Business Model", "Technology", "Policy", "Social", "Other" })
                                {
                                    <label class="flex items-center gap-xs p-sm border border-outline-variant rounded-sm cursor-pointer hover:bg-brand-cream">
                                        <input type="checkbox" name="InnovationTypes" value="@type" @(Model.InnovationTypes.Contains(type) ? "checked" : "") class="accent-brand-gold" />
                                        <span class="font-label-sm text-label-sm">@type</span>
                                    </label>
                                }
                            </div>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="Enablers">Enablers (Technology, Partners, Resources)</label>
                            <textarea asp-for="Enablers" rows="2" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md"></textarea>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="PotentialImpact">Potential Impact</label>
                            <textarea asp-for="PotentialImpact" rows="2" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md"></textarea>
                        </div>
                    </div>
                </div>
            }
            else if (Model.CurrentStep == 3)
            {
                <div class="space-y-md">
                    <h3 class="font-title-md text-title-md font-bold text-brand-maroon">Benefits & Strategic Alignment</h3>
                    <div class="grid grid-cols-1 gap-md">
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface" asp-for="Benefits">Benefits <span class="text-red-500">*</span></label>
                            <textarea asp-for="Benefits" rows="4" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" required></textarea>
                            <span asp-validation-for="Benefits" class="text-red-500 font-label-sm text-label-sm"></span>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface">Strategic Alignment</label>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-sm">
                                @foreach (var align in new[] { "Digital Transformation", "Financial Inclusion", "Operational Efficiency", "Risk Management", "Customer Experience", "Revenue Growth", "Regulatory Compliance", "Sustainability" })
                                {
                                    <label class="flex items-center gap-xs p-sm border border-outline-variant rounded-sm cursor-pointer hover:bg-brand-cream">
                                        <input type="checkbox" name="StrategicAlignments" value="@align" @(Model.StrategicAlignments.Contains(align) ? "checked" : "") class="accent-brand-gold" />
                                        <span class="font-label-sm text-label-sm">@align</span>
                                    </label>
                                }
                            </div>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="font-label-md text-label-md text-on-surface">SDG Alignment</label>
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-sm">
                                @foreach (var sdg in new[] { "SDG 1: No Poverty", "SDG 8: Decent Work", "SDG 9: Industry & Innovation", "SDG 10: Reduced Inequality", "SDG 11: Sustainable Cities", "SDG 13: Climate Action", "SDG 16: Peace & Justice", "SDG 17: Partnerships" })
                                {
                                    <label class="flex items-center gap-xs p-sm border border-outline-variant rounded-sm cursor-pointer hover:bg-brand-cream">
                                        <input type="checkbox" name="SdgAlignments" value="@sdg" @(Model.SdgAlignments.Contains(sdg) ? "checked" : "") class="accent-brand-gold" />
                                        <span class="font-label-sm text-label-sm">@sdg</span>
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (Model.CurrentStep == 4)
            {
                <div class="space-y-md">
                    <h3 class="font-title-md text-title-md font-bold text-brand-maroon">Review & Submit</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-md bg-brand-cream p-md rounded-sm">
                        <div>
                            <h4 class="font-label-md text-label-md font-bold text-brand-maroon mb-sm">Innovator Details</h4>
                            <div class="space-y-1 font-body-sm text-body-sm text-on-surface-variant">
                                <p><span class="font-medium">Name:</span> @Model.FullName</p>
                                <p><span class="font-medium">Email:</span> @Model.Email</p>
                                <p><span class="font-medium">Department:</span> @Model.Department</p>
                                <p><span class="font-medium">Job Title:</span> @Model.JobTitle</p>
                                <p><span class="font-medium">Location:</span> @Model.Location</p>
                            </div>
                        </div>
                        <div>
                            <h4 class="font-label-md text-label-md font-bold text-brand-maroon mb-sm">Idea Details</h4>
                            <div class="space-y-1 font-body-sm text-body-sm text-on-surface-variant">
                                <p><span class="font-medium">Title:</span> @Model.IdeaTitle</p>
                                <p><span class="font-medium">Summary:</span> @Model.Summary</p>
                                <p><span class="font-medium">Problem:</span> @Model.ProblemStatement</p>
                                <p><span class="font-medium">Solution:</span> @Model.ProposedSolution</p>
                                <p><span class="font-medium">Innovation Types:</span> @string.Join(", ", Model.InnovationTypes)</p>
                                <p><span class="font-medium">Enablers:</span> @Model.Enablers</p>
                                <p><span class="font-medium">Impact:</span> @Model.PotentialImpact</p>
                            </div>
                        </div>
                        <div class="md:col-span-2">
                            <h4 class="font-label-md text-label-md font-bold text-brand-maroon mb-sm">Benefits & Alignment</h4>
                            <div class="space-y-1 font-body-sm text-body-sm text-on-surface-variant">
                                <p><span class="font-medium">Benefits:</span> @Model.Benefits</p>
                                <p><span class="font-medium">Strategic Alignment:</span> @string.Join(", ", Model.StrategicAlignments)</p>
                                <p><span class="font-medium">SDG Alignment:</span> @string.Join(", ", Model.SdgAlignments)</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="flex items-center justify-between pt-md border-t border-outline-variant">
                @if (Model.CurrentStep > 1)
                {
                    <button type="submit" name="CurrentStep" value="@(Model.CurrentStep - 1)" class="bg-surface-container-low text-on-surface font-label-md text-label-md py-2.5 px-lg rounded-sm border border-outline-variant hover:bg-brand-cream transition-colors">Previous</button>
                }
                else
                {
                    <a asp-page="/StaffUser/Dashboard" class="bg-surface-container-low text-on-surface font-label-md text-label-md py-2.5 px-lg rounded-sm border border-outline-variant hover:bg-brand-cream transition-colors">Cancel</a>
                }
                @if (Model.CurrentStep < 4)
                {
                    <button type="submit" name="CurrentStep" value="@(Model.CurrentStep + 1)" class="bg-brand-gold hover:bg-secondary text-white font-label-md text-label-md py-2.5 px-lg rounded-sm transition-colors">Next</button>
                }
                else
                {
                    <button type="submit" class="bg-brand-maroon hover:bg-brand-maroon/90 text-white font-label-md text-label-md py-2.5 px-lg rounded-sm transition-colors">Submit Idea</button>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
