@page
@model IMTS.Pages.StaffUser.MyIdeasModel
@{
    string StatusBadge(string status) => status switch
    {
        "Under Review" => "bg-yellow-100 text-yellow-800",
        "In Development" => "bg-blue-100 text-blue-800",
        "Approved" => "bg-green-100 text-green-800",
        "Declined" => "bg-red-100 text-red-800",
        "Pending" => "bg-yellow-50 text-yellow-600",
        _ => "bg-gray-100 text-gray-800"
    };
}

<div class="space-y-lg">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-md">
        <form method="get" class="flex items-center gap-sm w-full sm:w-auto">
            <div class="relative flex-1 sm:min-w-[320px]">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
                <input type="text" name="search" value="@Model.SearchTerm" class="w-full pl-10 pr-4 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" placeholder="Search ideas by title, category or status..." />
            </div>
            <button type="submit" class="bg-brand-gold hover:bg-secondary text-white font-label-md text-label-md py-2.5 px-lg rounded-sm transition-colors">Search</button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a asp-page="/StaffUser/MyIdeas" class="font-label-md text-label-md text-outline hover:text-brand-maroon">Clear</a>
            }
        </form>
        <a asp-page="/StaffUser/SubmitIdea" class="bg-brand-maroon hover:bg-brand-maroon/90 text-white font-label-md text-label-md py-2.5 px-lg rounded-sm flex items-center gap-xs transition-colors">
            <span class="material-symbols-outlined">add</span>
            Submit New Idea
        </a>
    </div>

    <div class="bg-white rounded-sm shadow-soft overflow-hidden">
        @if (Model.Ideas.Count == 0)
        {
            <div class="text-center py-xl text-on-surface-variant">
                <span class="material-symbols-outlined text-5xl">inbox</span>
                <p class="font-body-md text-body-md mt-sm">No ideas found.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="bg-brand-cream border-b border-outline-variant">
                            <th class="text-left font-label-md text-label-md text-on-surface-variant py-sm px-md">Title</th>
                            <th class="text-left font-label-md text-label-md text-on-surface-variant py-sm px-md">Category</th>
                            <th class="text-left font-label-md text-label-md text-on-surface-variant py-sm px-md">Date</th>
                            <th class="text-left font-label-md text-label-md text-on-surface-variant py-sm px-md">Status</th>
                            <th class="text-left font-label-md text-label-md text-on-surface-variant py-sm px-md">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var idea in Model.Ideas)
                        {
                            <tr class="border-b border-outline-variant hover:bg-brand-cream/50 transition-colors">
                                <td class="py-sm px-md font-body-md text-body-md text-brand-maroon font-medium">@idea.Title</td>
                                <td class="py-sm px-md font-label-sm text-label-sm text-on-surface-variant">@idea.Category</td>
                                <td class="py-sm px-md font-label-sm text-label-sm text-on-surface-variant">@idea.SubmittedDate.ToString("MMM dd, yyyy")</td>
                                <td class="py-sm px-md"><span class="font-label-sm text-label-sm px-sm py-0.5 rounded-full @StatusBadge(idea.Status)">@idea.Status</span></td>
                                <td class="py-sm px-md">
                                    <a asp-page="/StaffUser/IdeaDetails" asp-route-id="@idea.Id" class="font-label-md text-label-md text-brand-gold hover:underline flex items-center gap-xs">
                                        <span class="material-symbols-outlined text-[18px]">visibility</span> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
