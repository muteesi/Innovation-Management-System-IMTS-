@page
@model IMTS.Pages.StaffUser.ResourcesModel

<div class="space-y-lg">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-md">
        <div class="bg-white rounded-sm shadow-soft p-md flex flex-col items-center text-center hover:shadow-md transition-shadow">
            <div class="w-16 h-16 rounded-full bg-brand-maroon/10 flex items-center justify-center mb-sm">
                <span class="material-symbols-outlined text-3xl text-brand-maroon">picture_as_pdf</span>
            </div>
            <h3 class="font-title-sm text-title-sm font-bold text-brand-maroon mb-xs">Innovation Guidelines</h3>
            <p class="font-body-sm text-body-sm text-on-surface-variant mb-md flex-1">Complete guide to the innovation submission process and evaluation criteria.</p>
            <a href="#" class="bg-brand-gold hover:bg-secondary text-white font-label-md text-label-md py-2 px-md rounded-sm inline-flex items-center gap-xs transition-colors">
                <span class="material-symbols-outlined text-[18px]">download</span> Download PDF
            </a>
        </div>

        <div class="bg-white rounded-sm shadow-soft p-md flex flex-col items-center text-center hover:shadow-md transition-shadow">
            <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mb-sm">
                <span class="material-symbols-outlined text-3xl text-blue-600">handyman</span>
            </div>
            <h3 class="font-title-sm text-title-sm font-bold text-brand-maroon mb-xs">Design Thinking Toolkit</h3>
            <p class="font-body-sm text-body-sm text-on-surface-variant mb-md flex-1">Templates and exercises for human-centered design thinking workshops.</p>
            <a href="#" class="bg-brand-gold hover:bg-secondary text-white font-label-md text-label-md py-2 px-md rounded-sm inline-flex items-center gap-xs transition-colors">
                <span class="material-symbols-outlined text-[18px]">download</span> Download ZIP
            </a>
        </div>

        <div class="bg-white rounded-sm shadow-soft p-md flex flex-col items-center text-center hover:shadow-md transition-shadow">
            <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mb-sm">
                <span class="material-symbols-outlined text-3xl text-green-600">folder_zip</span>
            </div>
            <h3 class="font-title-sm text-title-sm font-bold text-brand-maroon mb-xs">Budget Templates</h3>
            <p class="font-body-sm text-body-sm text-on-surface-variant mb-md flex-1">Standard budget planning templates for innovation project proposals.</p>
            <a href="#" class="bg-brand-gold hover:bg-secondary text-white font-label-md text-label-md py-2 px-md rounded-sm inline-flex items-center gap-xs transition-colors">
                <span class="material-symbols-outlined text-[18px]">download</span> Download XLSX
            </a>
        </div>

        <div class="bg-white rounded-sm shadow-soft p-md flex flex-col items-center text-center hover:shadow-md transition-shadow">
            <div class="w-16 h-16 rounded-full bg-purple-100 flex items-center justify-center mb-sm">
                <span class="material-symbols-outlined text-3xl text-purple-600">auto_stories</span>
            </div>
            <h3 class="font-title-sm text-title-sm font-bold text-brand-maroon mb-xs">Case Studies</h3>
            <p class="font-body-sm text-body-sm text-on-surface-variant mb-md flex-1">Successful innovation case studies from global financial institutions.</p>
            <a href="#" class="bg-brand-gold hover:bg-secondary text-white font-label-md text-label-md py-2 px-md rounded-sm inline-flex items-center gap-xs transition-colors">
                <span class="material-symbols-outlined text-[18px]">download</span> Download PDF
            </a>
        </div>
    </div>
</div>
