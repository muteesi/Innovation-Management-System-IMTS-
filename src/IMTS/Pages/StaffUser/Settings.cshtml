@page
@model IMTS.Pages.StaffUser.SettingsModel

<div class="max-w-3xl mx-auto space-y-lg">
    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="bg-green-100 text-green-800 p-md rounded-sm font-label-md text-label-md">@TempData["SuccessMessage"]</div>
    }

    <form method="post" class="space-y-lg">
        <div class="bg-white rounded-sm shadow-soft p-lg">
            <h3 class="font-title-md text-title-md font-bold text-brand-maroon mb-md flex items-center gap-xs">
                <span class="material-symbols-outlined">person</span> Profile Information
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                <div class="flex flex-col gap-1.5">
                    <label class="font-label-md text-label-md text-on-surface" asp-for="FullName">Full Name</label>
                    <input asp-for="FullName" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="font-label-md text-label-md text-on-surface" asp-for="Email">Email</label>
                    <input asp-for="Email" type="email" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="font-label-md text-label-md text-on-surface" asp-for="Department">Department</label>
                    <input asp-for="Department" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" />
                </div>
            </div>
        </div>

        <div class="bg-white rounded-sm shadow-soft p-lg">
            <h3 class="font-title-md text-title-md font-bold text-brand-maroon mb-md flex items-center gap-xs">
                <span class="material-symbols-outlined">notifications</span> Notification Preferences
            </h3>
            <div class="space-y-md">
                <label class="flex items-center justify-between p-sm border border-outline-variant rounded-sm cursor-pointer hover:bg-brand-cream transition-colors">
                    <div>
                        <p class="font-body-md text-body-md font-medium">Status Changes</p>
                        <p class="font-label-sm text-label-sm text-outline">Get notified when your idea status changes</p>
                    </div>
                    <input type="checkbox" asp-for="NotifyStatusChanges" class="w-5 h-5 rounded accent-brand-gold" />
                </label>
                <label class="flex items-center justify-between p-sm border border-outline-variant rounded-sm cursor-pointer hover:bg-brand-cream transition-colors">
                    <div>
                        <p class="font-body-md text-body-md font-medium">Comments</p>
                        <p class="font-label-sm text-label-sm text-outline">Get notified when someone comments on your idea</p>
                    </div>
                    <input type="checkbox" asp-for="NotifyComments" class="w-5 h-5 rounded accent-brand-gold" />
                </label>
                <label class="flex items-center justify-between p-sm border border-outline-variant rounded-sm cursor-pointer hover:bg-brand-cream transition-colors">
                    <div>
                        <p class="font-body-md text-body-md font-medium">Reminders</p>
                        <p class="font-label-sm text-label-sm text-outline">Get notified about submission deadlines and events</p>
                    </div>
                    <input type="checkbox" asp-for="NotifyReminders" class="w-5 h-5 rounded accent-brand-gold" />
                </label>
            </div>
        </div>

        <div class="bg-white rounded-sm shadow-soft p-lg">
            <h3 class="font-title-md text-title-md font-bold text-brand-maroon mb-md flex items-center gap-xs">
                <span class="material-symbols-outlined">lock</span> Change Password
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
                <div class="flex flex-col gap-1.5">
                    <label class="font-label-md text-label-md text-on-surface" asp-for="CurrentPassword">Current Password</label>
                    <input asp-for="CurrentPassword" type="password" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="font-label-md text-label-md text-on-surface" asp-for="NewPassword">New Password</label>
                    <input asp-for="NewPassword" type="password" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="font-label-md text-label-md text-on-surface" asp-for="ConfirmPassword">Confirm New Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="w-full px-3 py-2.5 bg-surface-container-lowest border border-outline-variant focus:border-brand-gold focus:ring-1 focus:ring-brand-gold rounded-sm outline-none font-body-md text-body-md" />
                </div>
            </div>
        </div>

        <div class="flex justify-end">
            <button type="submit" class="bg-brand-gold hover:bg-secondary text-white font-label-md text-label-md py-2.5 px-lg rounded-sm transition-colors">Save Settings</button>
        </div>
    </form>
</div>
