@page
@model IMTS.Pages.InnovationTeam.DashboardModel
@{
    ViewData["Title"] = "Innovation Team Dashboard";
}
<div class="space-y-lg">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-md">
        <div class="bg-white rounded-sm border border-outline-variant p-md shadow-soft flex flex-col items-start gap-xs">
            <span class="material-symbols-outlined text-brand-gold text-[28px]">lightbulb</span>
            <span class="font-label-sm text-label-sm text-on-surface-variant">Total Ideas</span>
            <span class="font-headline-md text-headline-md font-bold text-brand-maroon">@Model.TotalIdeas</span>
        </div>
        <div class="bg-white rounded-sm border border-outline-variant p-md shadow-soft flex flex-col items-start gap-xs">
            <span class="material-symbols-outlined text-amber-500 text-[28px]">pending_actions</span>
            <span class="font-label-sm text-label-sm text-on-surface-variant">Pending Review</span>
            <span class="font-headline-md text-headline-md font-bold text-amber-600">@Model.PendingReview</span>
        </div>
        <div class="bg-white rounded-sm border border-outline-variant p-md shadow-soft flex flex-col items-start gap-xs">
            <span class="material-symbols-outlined text-blue-500 text-[28px]">construction</span>
            <span class="font-label-sm text-label-sm text-on-surface-variant">In Development</span>
            <span class="font-headline-md text-headline-md font-bold text-blue-600">@Model.InDevelopment</span>
        </div>
        <div class="bg-white rounded-sm border border-outline-variant p-md shadow-soft flex flex-col items-start gap-xs">
            <span class="material-symbols-outlined text-green-500 text-[28px]">check_circle</span>
            <span class="font-label-sm text-label-sm text-on-surface-variant">Deployed</span>
            <span class="font-headline-md text-headline-md font-bold text-green-600">@Model.Deployed</span>
        </div>
        <div class="bg-white rounded-sm border border-outline-variant p-md shadow-soft flex flex-col items-start gap-xs">
            <span class="material-symbols-outlined text-emerald-500 text-[28px]">verified</span>
            <span class="font-label-sm text-label-sm text-on-surface-variant">Approved</span>
            <span class="font-headline-md text-headline-md font-bold text-emerald-600">@Model.Approved</span>
        </div>
        <div class="bg-white rounded-sm border border-outline-variant p-md shadow-soft flex flex-col items-start gap-xs">
            <span class="material-symbols-outlined text-red-500 text-[28px]">cancel</span>
            <span class="font-label-sm text-label-sm text-on-surface-variant">Declined</span>
            <span class="font-headline-md text-headline-md font-bold text-red-600">@Model.Declined</span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
        <div class="lg:col-span-2 bg-white rounded-sm border border-outline-variant shadow-soft p-md">
            <div class="flex items-center justify-between mb-md">
                <h2 class="font-title-md text-title-md font-bold text-brand-maroon">Pending Submissions</h2>
                <a asp-page="/InnovationTeam/ReviewIdeas" class="text-brand-gold font-label-md text-label-md hover:underline">View All</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead>
                        <tr class="border-b border-outline-variant text-on-surface-variant font-label-sm text-label-sm">
                            <th class="py-2 pr-2"><input type="checkbox" class="rounded border-outline-variant" /></th>
                            <th class="py-2 pr-2">Idea Title</th>
                            <th class="py-2 pr-2">Submitter</th>
                            <th class="py-2 pr-2">Date</th>
                            <th class="py-2 pr-2">Category</th>
                            <th class="py-2 pr-2">Status</th>
                            <th class="py-2 pr-2">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var idea in Model.Ideas.Take(5))
                        {
                            <tr class="border-b border-outline-variant/50 hover:bg-brand-cream transition-colors">
                                <td class="py-3 pr-2"><input type="checkbox" class="rounded border-outline-variant" /></td>
                                <td class="py-3 pr-2 font-medium text-on-surface">@idea.Title</td>
                                <td class="py-3 pr-2 text-on-surface-variant">@idea.Submitter</td>
                                <td class="py-3 pr-2 text-on-surface-variant">@idea.SubmittedDate.ToString("MMM dd, yyyy")</td>
                                <td class="py-3 pr-2"><span class="bg-brand-soft-yellow text-brand-maroon font-label-sm text-label-sm px-2 py-0.5 rounded-sm">@idea.Category</span></td>
                                <td class="py-3 pr-2">
                                    <span class="inline-flex items-center gap-1 font-label-sm text-label-sm @(idea.Status == "Under Review" ? "text-amber-600" : idea.Status == "Approved" ? "text-green-600" : idea.Status == "Declined" ? "text-red-600" : "text-blue-600")">
                                        <span class="w-1.5 h-1.5 rounded-full @(idea.Status == "Under Review" ? "bg-amber-500" : idea.Status == "Approved" ? "bg-green-500" : idea.Status == "Declined" ? "bg-red-500" : "bg-blue-500")"></span>
                                        @idea.Status
                                    </span>
                                </td>
                                <td class="py-3 pr-2">
                                    <button class="text-brand-gold hover:text-[#c47e1d] font-label-sm text-label-sm" title="Review">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="space-y-md">
            <div class="bg-white rounded-sm border border-outline-variant shadow-soft p-md">
                <h3 class="font-title-md text-title-md font-bold text-brand-maroon mb-sm">Quick Actions</h3>
                <div class="space-y-2">
                    <a asp-page="/InnovationTeam/ReviewIdeas" class="flex items-center gap-2 w-full p-sm bg-brand-gold/10 text-brand-maroon rounded-sm hover:bg-brand-gold/20 transition-colors font-label-md text-label-md">
                        <span class="material-symbols-outlined text-[20px]">rate_review</span> Review Pending Ideas
                    </a>
                    <a asp-page="/InnovationTeam/ManageCategories" class="flex items-center gap-2 w-full p-sm bg-brand-gold/10 text-brand-maroon rounded-sm hover:bg-brand-gold/20 transition-colors font-label-md text-label-md">
                        <span class="material-symbols-outlined text-[20px]">category</span> Manage Categories
                    </a>
                    <a asp-page="/InnovationTeam/SetTimelines" class="flex items-center gap-2 w-full p-sm bg-brand-gold/10 text-brand-maroon rounded-sm hover:bg-brand-gold/20 transition-colors font-label-md text-label-md">
                        <span class="material-symbols-outlined text-[20px]">calendar_today</span> Set Timelines
                    </a>
                </div>
            </div>
            <div class="bg-white rounded-sm border border-outline-variant shadow-soft p-md">
                <h3 class="font-title-md text-title-md font-bold text-brand-maroon mb-sm">Development Pipeline</h3>
                <div class="space-y-3">
                    <div>
                        <div class="flex justify-between font-label-sm text-label-sm mb-1">
                            <span class="text-on-surface">Micro-Loan AI Risk Engine</span>
                            <span class="text-brand-gold">62%</span>
                        </div>
                        <div class="w-full h-2 bg-outline-variant/50 rounded-full overflow-hidden">
                            <div class="h-full bg-brand-gold rounded-full" style="width:62%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between font-label-sm text-label-sm mb-1">
                            <span class="text-on-surface">Fraud Detection Dashboard</span>
                            <span class="text-brand-gold">38%</span>
                        </div>
                        <div class="w-full h-2 bg-outline-variant/50 rounded-full overflow-hidden">
                            <div class="h-full bg-brand-gold rounded-full" style="width:38%"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-white rounded-sm border border-outline-variant shadow-soft p-md">
                <h3 class="font-title-md text-title-md font-bold text-brand-maroon mb-sm">Upcoming Deadlines</h3>
                <div class="space-y-2">
                    <div class="flex items-center gap-2 font-label-sm text-label-sm">
                        <span class="material-symbols-outlined text-red-500 text-[18px]">event</span>
                        <span class="text-on-surface">Q4 Idea Cutoff</span>
                        <span class="ml-auto text-on-surface-variant">Oct 25</span>
                    </div>
                    <div class="flex items-center gap-2 font-label-sm text-label-sm">
                        <span class="material-symbols-outlined text-amber-500 text-[18px]">event</span>
                        <span class="text-on-surface">Panel Review</span>
                        <span class="ml-auto text-on-surface-variant">Nov 2</span>
                    </div>
                    <div class="flex items-center gap-2 font-label-sm text-label-sm">
                        <span class="material-symbols-outlined text-blue-500 text-[18px]">event</span>
                        <span class="text-on-surface">Prototype Submission</span>
                        <span class="ml-auto text-on-surface-variant">Dec 1</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <button class="fixed bottom-6 right-6 w-14 h-14 bg-brand-gold hover:bg-[#c47e1d] text-white rounded-full shadow-lg flex items-center justify-center transition-all active:scale-95 z-50" title="Quick Actions">
        <span class="material-symbols-outlined text-[28px]">add</span>
    </button>
</div>
