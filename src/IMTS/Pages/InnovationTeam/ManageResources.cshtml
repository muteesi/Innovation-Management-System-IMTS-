@page
@model IMTS.Pages.InnovationTeam.ManageResourcesModel
@{
    ViewData["Title"] = "Manage Resources";
}
<div class="space-y-lg">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="bg-green-50 border border-green-200 text-green-700 font-label-md text-label-md p-sm rounded-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-[20px]">check_circle</span>
            @Model.SuccessMessage
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
        <div class="lg:col-span-2 bg-white rounded-sm border border-outline-variant shadow-soft p-md">
            <h2 class="font-title-md text-title-md font-bold text-brand-maroon mb-md">All Resources</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead>
                        <tr class="border-b border-outline-variant text-on-surface-variant font-label-sm text-label-sm">
                            <th class="py-2 pr-2">Title</th>
                            <th class="py-2 pr-2">Type</th>
                            <th class="py-2 pr-2">Description</th>
                            <th class="py-2 pr-2">Upload Date</th>
                            <th class="py-2 pr-2">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var res in Model.Resources)
                        {
                            <tr class="border-b border-outline-variant/50 hover:bg-brand-cream transition-colors">
                                <td class="py-3 pr-2 font-medium text-on-surface">@res.Title</td>
                                <td class="py-3 pr-2">
                                    <span class="bg-brand-soft-yellow text-brand-maroon font-label-sm text-label-sm px-2 py-0.5 rounded-sm">@res.Type</span>
                                </td>
                                <td class="py-3 pr-2 text-on-surface-variant max-w-xs truncate">@res.Description</td>
                                <td class="py-3 pr-2 text-on-surface-variant">@res.UploadDate.ToString("MMM dd, yyyy")</td>
                                <td class="py-3 pr-2">
                                    <div class="flex items-center gap-2">
                                        <button class="text-brand-gold hover:text-[#c47e1d] transition-colors" title="Edit">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </button>
                                        <button class="text-red-500 hover:text-red-700 transition-colors" title="Delete">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                        <button class="text-blue-500 hover:text-blue-700 transition-colors" title="Download">
                                            <span class="material-symbols-outlined text-[20px]">download</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="bg-white rounded-sm border border-outline-variant shadow-soft p-md">
            <h2 class="font-title-md text-title-md font-bold text-brand-maroon mb-md">Upload New Resource</h2>
            <form method="post" asp-page-handler="Add" class="space-y-3">
                <div>
                    <label class="font-label-sm text-label-sm text-on-surface block mb-1" asp-for="NewTitle">Title</label>
                    <input asp-for="NewTitle" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none" placeholder="Resource title" required />
                </div>
                <div>
                    <label class="font-label-sm text-label-sm text-on-surface block mb-1" asp-for="NewType">Type</label>
                    <select asp-for="NewType" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none">
                        <option value="">Select type...</option>
                        @foreach (var t in Model.ResourceTypes)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="font-label-sm text-label-sm text-on-surface block mb-1" asp-for="NewDescription">Description</label>
                    <textarea asp-for="NewDescription" rows="3" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none resize-none" placeholder="Brief description..."></textarea>
                </div>
                <div>
                    <label class="font-label-sm text-label-sm text-on-surface block mb-1">File</label>
                    <input type="file" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm file:mr-3 file:py-1.5 file:px-3 file:rounded-sm file:border-0 file:bg-brand-gold file:text-white file:text-sm file:cursor-pointer" />
                </div>
                <button type="submit" class="w-full bg-brand-gold hover:bg-[#c47e1d] text-white font-label-sm text-label-sm py-3 rounded-sm transition-colors">Upload Resource</button>
            </form>
        </div>
    </div>
</div>
