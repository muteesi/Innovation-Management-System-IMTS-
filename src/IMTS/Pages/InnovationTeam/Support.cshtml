@page
@model IMTS.Pages.InnovationTeam.SupportModel
@{
    ViewData["Title"] = "Support";
}
<div class="space-y-lg">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="bg-green-50 border border-green-200 text-green-700 font-label-md text-label-md p-sm rounded-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-[20px]">check_circle</span>
            @Model.SuccessMessage
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
        <div class="lg:col-span-2 space-y-md">
            <div class="bg-white rounded-sm border border-outline-variant shadow-soft p-md">
                <h2 class="font-title-md text-title-md font-bold text-brand-maroon mb-md">Frequently Asked Questions</h2>
                <div id="faq-accordion" class="space-y-2">
                    @foreach (var faq in Model.FaqItems)
                    {
                        <div class="border border-outline-variant/50 rounded-sm">
                            <button type="button" class="w-full flex items-center justify-between p-sm text-left font-label-md text-label-md font-medium text-on-surface hover:bg-brand-cream transition-colors" onclick="toggleFaq(@faq.Id)">
                                <span>@faq.Question</span>
                                <span class="material-symbols-outlined text-brand-gold transition-transform" id="faq-icon-@faq.Id">expand_more</span>
                            </button>
                            <div id="faq-answer-@faq.Id" class="hidden px-sm pb-sm font-body-md text-body-md text-on-surface-variant">
                                @faq.Answer
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="bg-white rounded-sm border border-outline-variant shadow-soft p-md">
                <h2 class="font-title-md text-title-md font-bold text-brand-maroon mb-md">Contact IT Support</h2>
                <form method="post" class="space-y-3">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <div>
                            <label class="font-label-sm text-label-sm text-on-surface block mb-1" asp-for="ContactName">Name</label>
                            <input asp-for="ContactName" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none" placeholder="Your name" required />
                        </div>
                        <div>
                            <label class="font-label-sm text-label-sm text-on-surface block mb-1" asp-for="ContactEmail">Email</label>
                            <input asp-for="ContactEmail" type="email" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none" placeholder="your.email@bou.or.ug" required />
                        </div>
                    </div>
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface block mb-1" asp-for="ContactSubject">Subject</label>
                        <input asp-for="ContactSubject" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none" placeholder="What is this about?" required />
                    </div>
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface block mb-1" asp-for="ContactMessage">Message</label>
                        <textarea asp-for="ContactMessage" rows="4" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none resize-none" placeholder="Describe your issue..." required></textarea>
                    </div>
                    <button type="submit" class="bg-brand-gold hover:bg-[#c47e1d] text-white font-label-sm text-label-sm px-6 py-3 rounded-sm transition-colors">Send Message</button>
                </form>
            </div>
        </div>

        <div class="bg-white rounded-sm border border-outline-variant shadow-soft p-md h-fit">
            <h2 class="font-title-md text-title-md font-bold text-brand-maroon mb-md">Support Contact</h2>
            <div class="space-y-4">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-brand-gold text-[24px]">phone</span>
                    <div>
                        <p class="font-label-sm text-label-sm text-on-surface-variant">Phone</p>
                        <p class="font-label-md text-label-md text-on-surface">+256 414 123 456</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-brand-gold text-[24px]">mail</span>
                    <div>
                        <p class="font-label-sm text-label-sm text-on-surface-variant">Email</p>
                        <p class="font-label-md text-label-md text-on-surface">itsupport@bou.or.ug</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-brand-gold text-[24px]">schedule</span>
                    <div>
                        <p class="font-label-sm text-label-sm text-on-surface-variant">Working Hours</p>
                        <p class="font-label-md text-label-md text-on-surface">Mon - Fri, 8:00 AM - 5:00 PM</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function toggleFaq(id) {
            var answer = document.getElementById('faq-answer-' + id);
            var icon = document.getElementById('faq-icon-' + id);
            answer.classList.toggle('hidden');
            icon.textContent = answer.classList.contains('hidden') ? 'expand_more' : 'expand_less';
        }
    </script>
}
