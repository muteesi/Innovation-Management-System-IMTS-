@page
@model IMTS.Pages.InnovationTeam.ReviewIdeasModel
@{
    ViewData["Title"] = "Review Ideas";
}
<div class="space-y-lg">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="bg-green-50 border border-green-200 text-green-700 font-label-md text-label-md p-sm rounded-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-[20px]">check_circle</span>
            @Model.SuccessMessage
        </div>
    }

    <div class="flex flex-col md:flex-row gap-md items-start md:items-center justify-between">
        <div class="flex items-center gap-sm">
            <label class="font-label-sm text-label-sm text-on-surface-variant">Filter by Category:</label>
            <select asp-for="SelectedCategory" class="border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat">@cat</option>
                }
            </select>
        </div>
        <form method="post" asp-page-handler="Bulk" class="flex items-center gap-sm">
            <select asp-for="BulkAction" class="border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none">
                <option value="">Bulk Actions</option>
                <option value="approve">Approve Selected</option>
                <option value="decline">Decline Selected</option>
                <option value="request changes">Request Changes</option>
            </select>
            <button type="submit" class="bg-brand-gold hover:bg-[#c47e1d] text-white font-label-sm text-label-sm px-4 py-2 rounded-sm transition-colors">Apply</button>
        </form>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
        @foreach (var idea in Model.Ideas)
        {
            <div class="bg-white rounded-sm border border-outline-variant shadow-soft p-md relative">
                <div class="flex items-start gap-3">
                    <input type="checkbox" class="mt-1 rounded border-outline-variant" />
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-2">
                            <h3 class="font-title-md text-title-md font-bold text-on-surface truncate">@idea.Title</h3>
                            <span class="text-xs bg-brand-soft-yellow text-brand-maroon px-2 py-0.5 rounded-sm whitespace-nowrap">@idea.Category</span>
                        </div>
                        <p class="font-label-sm text-label-sm text-on-surface-variant mt-1">
                            <span class="material-symbols-outlined text-[14px]">person</span> @idea.Submitter
                            <span class="mx-1">|</span>
                            <span class="material-symbols-outlined text-[14px]">calendar_today</span> @idea.SubmittedDate.ToString("MMM dd, yyyy")
                        </p>
                        <p class="font-body-md text-body-md text-on-surface-variant mt-2 line-clamp-2">@idea.Summary</p>
                        <div class="mt-3 flex gap-2">
                            <button type="button" class="bg-brand-gold hover:bg-[#c47e1d] text-white font-label-sm text-label-sm px-3 py-1.5 rounded-sm transition-colors" onclick="openReview(@idea.Id, '@idea.Title')">Review</button>
                        </div>
                    </div>
                </div>
                <div id="review-panel-@idea.Id" class="hidden mt-md border-t border-outline-variant pt-md">
                    <form method="post" asp-page="/InnovationTeam/ReviewIdeas">
                        <input type="hidden" asp-for="ReviewIdeaId" value="@idea.Id" />
                        <div class="space-y-3">
                            <div>
                                <label class="font-label-sm text-label-sm text-on-surface block mb-1">Decision</label>
                                <select asp-for="ReviewDecision" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none">
                                    <option value="">Select decision...</option>
                                    <option value="Approve">Approve</option>
                                    <option value="Decline">Decline</option>
                                    <option value="Request Changes">Request Changes</option>
                                </select>
                            </div>
                            <div>
                                <label class="font-label-sm text-label-sm text-on-surface block mb-1">Score / Rating</label>
                                <div class="flex gap-1">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <label class="cursor-pointer">
                                            <input type="radio" asp-for="ReviewScore" value="@s" class="hidden peer" />
                                            <span class="material-symbols-outlined text-[28px] text-outline peer-checked:text-brand-gold">@(s <= Model.ReviewScore ? "star" : "star")</span>
                                        </label>
                                    }
                                </div>
                            </div>
                            <div>
                                <label class="font-label-sm text-label-sm text-on-surface block mb-1">Comments</label>
                                <textarea asp-for="ReviewComments" rows="3" class="w-full border border-outline-variant rounded-sm px-3 py-2 bg-white text-sm focus:border-brand-gold focus:ring-1 focus:ring-brand-gold outline-none resize-none" placeholder="Provide your feedback..."></textarea>
                            </div>
                            <button type="submit" class="bg-brand-gold hover:bg-[#c47e1d] text-white font-label-sm text-label-sm px-4 py-2 rounded-sm transition-colors">Submit Review</button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
@section Scripts {
    <script>
        function openReview(id, title) {
            var panel = document.getElementById('review-panel-' + id);
            panel.classList.toggle('hidden');
        }
    </script>
}
